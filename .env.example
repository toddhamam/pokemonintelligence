# Miami — Pokemon Market Intelligence
# Copy to .env and fill in values. Never commit .env.

# --- Local Postgres (docker-compose.dev.yml) ---
# Two URLs because the feature-compute role cannot read base snapshot tables;
# the API uses the app role, feature jobs use the feature_compute role.
MIAMI_DB_URL_APP=postgresql+psycopg://miami_app:miami_app@localhost:5433/miami
MIAMI_DB_URL_FEATURE_COMPUTE=postgresql+psycopg://miami_feature_compute:miami_feature_compute@localhost:5433/miami
MIAMI_DB_URL_OWNER=postgresql+psycopg://miami_owner:miami_owner@localhost:5433/miami

# --- Dev mode ---
# 1 = collectors return fixture payloads instead of hitting live APIs
MIAMI_DEV_MODE=1

# --- Source credentials (leave empty in dev mode) ---
PRICECHARTING_API_KEY=
POKEMONTCG_API_KEY=
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_OAUTH_TOKEN=
PSA_API_KEY=

# --- FastAPI <-> Next.js ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
FASTAPI_SERVICE_TOKEN=dev-service-token-change-in-prod
PIPELINE_REVALIDATE_TOKEN=dev-revalidate-token-change-in-prod
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Clerk (dev keys OK; https://clerk.com -> your app -> API Keys) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Sentry (optional in dev) ---
SENTRY_DSN_API=
NEXT_PUBLIC_SENTRY_DSN_WEB=

# --- Vercel Blob (optional in dev — payload archive falls back to local filesystem) ---
BLOB_READ_WRITE_TOKEN=

# --- Resend (alerts; optional in dev) ---
RESEND_API_KEY=
ALERTS_FROM_EMAIL=alerts@example.com
